generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum UserStatus {
  Active
  Suspended
  Deactivated
}

enum KycStatus {
  Pending
  Verified
  Rejected
  Expired
}

enum IncidentStatus {
  Submitted
  Received
  Verifying
  Verified
  Assigned
  Responding
  Resolved
  Closed
  FalseReport
}

enum IncidentPriority {
  P1LifeThreatening
  P2ActiveCrimeAccident
  P3SuspiciousActivity
  P4GeneralSafety
}

enum IncidentType {
  Emergency
  Crime
  Accident
  Fire
  Medical
  CommunitySafety
  Kidnapping
  Abuse
  SuspiciousActivity
  MissingPerson
  StolenVehicle
  SOS
}

enum MediaType {
  Image
  Video
  Audio
  Document
  LiveVideoRecording
}

enum BroadcastStatus {
  Draft
  PendingApproval
  Scheduled
  DispatchQueued
  Dispatching
  Published
  Failed
  Expired
  Cancelled
  Rejected
}

enum BroadcastType {
  Emergency
  Crime
  Accident
  MissingPerson
  StolenVehicle
  GovernmentAlert
  CommunityWarning
}

enum BroadcastDeliveryStatus {
  Queued
  Sent
  Delivered
  Failed
  Read
}

enum CommunityLevel {
  Country
  State
  LGA
  Ward
  Community
  Estate
  Street
}

enum CommunityVisibility {
  Public
  Private
}

enum CommunityStatus {
  Active
  Archived
  Suspended
}

enum CommunityRequestStatus {
  Pending
  Approved
  Rejected
}

enum CommunityReportTargetType {
  Post
  Comment
  Member
  Community
}

enum CommunityReportStatus {
  Pending
  Reviewed
  Dismissed
}

enum CommunityMembershipStatus {
  Pending
  Approved
  Rejected
  Left
  Suspended
  Banned
}

enum CommunityRoleName {
  CommunityModerator
  EstateAdmin
  SecurityCoordinator
  PoliceLiaison
  VolunteerCoordinator
  VerifiedVolunteer
  Resident
}

enum CommunityPostType {
  SuspiciousActivity
  LostChild
  MissingPerson
  CrimeAlert
  AccidentAlert
  FireAlert
  FloodWarning
  CommunityAnnouncement
  SecurityMeeting
  PatrolUpdate
}

enum CommunityVerificationStatus {
  PendingVerification
  Verified
  Disputed
  FalseInformation
}

enum CommunityReactionType {
  Confirm
  Helpful
  Praying
  Dispute
  Seen
}

enum CommunityChannelType {
  General
  Emergency
  Security
  Volunteers
  WomenSafety
  Parents
  BusinessOwners
}

enum VolunteerType {
  Doctor
  Nurse
  FirstAid
  Lawyer
  SecurityVolunteer
  FireVolunteer
  SearchAndRescue
  BloodDonor
}

enum PatrolStatus {
  Scheduled
  Active
  Completed
  Cancelled
}

enum NotificationStatus {
  Pending
  Sent
  Delivered
  Failed
  Read
}

enum ReportStatus {
  Draft
  Generated
  Reviewed
  Published
  Archived
}

enum EscalationStatus {
  Pending
  Notified
  Acknowledged
  Resolved
  Cancelled
}

enum ResponderAvailability {
  Offline
  Available
  Busy
  EnRoute
  OnScene
  OutOfService
}

enum ResponseUnitStatus {
  Offline
  Available
  Busy
  EnRoute
  OnScene
  OutOfService
}

enum IncidentAssignmentStatus {
  Proposed
  Assigned
  Accepted
  Declined
  Expired
  Reassigned
  EnRoute
  Arrived
  InProgress
  Completed
  Cancelled
}
model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  email                 String?                @unique
  phone                 String?                @unique
  passwordHash          String?                @map("password_hash")
  googleId              String?                @unique @map("google_id")
  phoneVerifiedAt       DateTime?              @map("phone_verified_at") @db.Timestamptz(6)
  status                UserStatus             @default(Active)
  isTrustedReporter     Boolean                @default(false) @map("is_trusted_reporter")
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile               Profile?
  kycRecords            KycRecord[]
  emergencyContacts     EmergencyContact[]
  reportedIncidents     Incident[]             @relation("IncidentReporter")
  uploadedMedia         IncidentMedia[]         @relation("MediaUploader")
  verifications         IncidentVerification[]
  timelineEvents        IncidentTimeline[]
  statusChanges         IncidentStatusHistory[] @relation("StatusChangedBy")
  vehicles              Vehicle[]
  stolenVehicleReports  StolenVehicleReport[]
  missingPersonReports  MissingPersonReport[]
  notifications         Notification[]
  pushTokens            UserPushToken[]
  broadcastDeliveries   BroadcastDelivery[]
  broadcastReads        BroadcastRead[]
  groupMessages         GroupMessage[]
  smartwatchDevices     SmartwatchDevice[]
  sosEvents             SosEvent[]
  auditLogs             AuditLog[]              @relation("AuditActor")
  trustedReporter       TrustedReporter?
  refreshTokens         RefreshToken[]
  phoneOtps             PhoneOtp[]
  passwordResetTokens   PasswordResetToken[]
  accountRecoveryChallenges AccountRecoveryChallenge[]
  mediaAccessLogs       IncidentMediaAccessLog[]
  communityMemberships  CommunityMembership[]
  communityPosts        CommunityPost[]
  communityPostMedia    CommunityPostMedia[]
  communityComments     CommunityPostComment[]
  communityReactions    CommunityPostReaction[]
  communityVerifications CommunityVerification[]
  communityMessages     CommunityMessage[]
  communityRequests     CommunityRequest[]
  communityContentReports CommunityContentReport[]
  volunteerProfile      VolunteerProfile?
  patrolAssignments     PatrolAssignment[]
  patrolCheckpoints     PatrolCheckpoint[]
  patrolReports         PatrolReport[]
  authAccounts          AuthAccount[]
  responderProfile      Responder?

  @@map("users")
}

model AuthAccount {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  provider        String
  providerSubject String   @map("provider_subject")
  providerEmail   String?  @map("provider_email")
  emailVerified   Boolean  @default(false) @map("email_verified")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("auth_accounts")
}

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      String?
  address     String?
  country     String
  state       String
  lga         String
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country, state, lga])
  @@map("profiles")
}

model KycRecord {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  documentType   String    @map("document_type")
  documentNumber String?   @map("document_number")
  documentHash   String    @map("document_hash")
  status         KycStatus @default(Pending)
  reviewedBy     String?   @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason String?  @map("rejection_reason")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("kyc_records")
}

model EmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  name         String
  phone        String
  relationship String
  priority     Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("emergency_contacts")
}

model Jurisdiction {
  id              String          @id @default(uuid()) @db.Uuid
  country         String
  state           String
  lga             String
  name            String
  boundary        Unsupported("geography(MultiPolygon,4326)")?
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  agencies        Agency[]
  adminUsers      AdminUser[]
  policeStations  PoliceStation[]
  broadcasts      Broadcast[]
  incidents       Incident[]
  neighborhoodGroups NeighborhoodGroup[]
  communities     Community[]

  @@unique([country, state, lga])
  @@index([country, state, lga])
  @@map("jurisdictions")
}

model Agency {
  id                 String               @id @default(uuid()) @db.Uuid
  jurisdictionId     String               @map("jurisdiction_id") @db.Uuid
  name               String
  type               String
  phone              String?
  email              String?
  serviceCategories  String[]             @default([]) @map("service_categories")
  isActive           Boolean              @default(true) @map("is_active")
  operatingHours     Json                 @default("{}") @map("operating_hours")
  escalationPriority Int                  @default(0) @map("escalation_priority")
  latitude           Decimal?             @db.Decimal(9, 6)
  longitude          Decimal?             @db.Decimal(9, 6)
  agencyLocation     Unsupported("geography(Point,4326)")? @map("agency_location")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  jurisdiction       Jurisdiction         @relation(fields: [jurisdictionId], references: [id])
  adminUsers         AdminUser[]
  incidents          Incident[]
  policeStations     PoliceStation[]
  responders         Responder[]
  responseUnits      ResponseUnit[]
  incidentAssignments IncidentAssignment[]

  @@index([jurisdictionId, type])
  @@index([jurisdictionId, isActive])
  @@map("agencies")
}

model AdminRole {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique
  permissions String[]    @default([])
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUsers  AdminUser[]

  @@map("admin_roles")
}

model AdminUser {
  id             String       @id @default(uuid()) @db.Uuid
  roleId         String       @map("role_id") @db.Uuid
  agencyId       String?      @map("agency_id") @db.Uuid
  jurisdictionId String       @map("jurisdiction_id") @db.Uuid
  email          String       @unique
  passwordHash   String       @map("password_hash")
  displayName    String       @map("display_name")
  country        String
  state          String
  lga            String
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  role           AdminRole    @relation(fields: [roleId], references: [id])
  agency         Agency?      @relation(fields: [agencyId], references: [id])
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  assignedIncidents Incident[] @relation("IncidentAssignedAdmin")
  broadcastsCreated Broadcast[] @relation("BroadcastCreator")
  broadcastsApproved Broadcast[] @relation("BroadcastApprover")
  reports        Report[]
  auditLogs      AuditLog[]    @relation("AuditAdminActor")
  refreshTokens RefreshToken[]
  responderProfile Responder?
  dispatchAssignmentsCreated IncidentAssignment[] @relation("AssignmentAssignedBy")
  dispatchEvents DispatchEvent[] @relation("DispatchEventActor")

  @@index([country, state, lga])
  @@index([jurisdictionId])
  @@map("admin_users")
}

model Incident {
  id                  String                  @id @default(uuid()) @db.Uuid
  reporterId          String?                 @map("reporter_id") @db.Uuid
  jurisdictionId      String                  @map("jurisdiction_id") @db.Uuid
  assignedAgencyId    String?                 @map("assigned_agency_id") @db.Uuid
  assignedAdminId     String?                 @map("assigned_admin_id") @db.Uuid
  type                IncidentType
  status              IncidentStatus          @default(Submitted)
  priority            IncidentPriority        @default(P4GeneralSafety)
  title               String
  description         String?
  address             String?
  country             String
  state               String
  lga                 String
  latitude            Decimal                 @db.Decimal(9, 6)
  longitude           Decimal                 @db.Decimal(9, 6)
  gpsLocation         Unsupported("geography(Point,4326)") @map("gps_location")
  manualLatitude      Decimal?                @map("manual_latitude") @db.Decimal(9, 6)
  manualLongitude     Decimal?                @map("manual_longitude") @db.Decimal(9, 6)
  manualGpsLocation   Unsupported("geography(Point,4326)")? @map("manual_gps_location")
  manualAddress       String?                 @map("manual_address")
  manualLocationAdjusted Boolean              @default(false) @map("manual_location_adjusted")
  isAnonymous         Boolean                 @default(false) @map("is_anonymous")
  notifyEmergencyContacts Boolean             @default(false) @map("notify_emergency_contacts")
  clientSubmissionId  String?                 @unique @map("client_submission_id")
  occurredAt          DateTime?               @map("occurred_at") @db.Timestamptz(6)
  submittedAt         DateTime                @default(now()) @map("submitted_at") @db.Timestamptz(6)
  metadata            Json                    @default("{}")
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  resolvedAt          DateTime?               @map("resolved_at") @db.Timestamptz(6)
  closedAt            DateTime?               @map("closed_at") @db.Timestamptz(6)
  liveLocationUpdatedAt DateTime?             @map("live_location_updated_at") @db.Timestamptz(6)
  liveLocationStale   Boolean                 @default(false) @map("live_location_stale")
  reporter            User?                   @relation("IncidentReporter", fields: [reporterId], references: [id])
  jurisdiction        Jurisdiction            @relation(fields: [jurisdictionId], references: [id])
  assignedAgency      Agency?                 @relation(fields: [assignedAgencyId], references: [id])
  assignedAdmin       AdminUser?              @relation("IncidentAssignedAdmin", fields: [assignedAdminId], references: [id])
  media               IncidentMedia[]
  verifications       IncidentVerification[]
  timeline            IncidentTimeline[]
  statusHistory       IncidentStatusHistory[]
  locationUpdates     IncidentLocationUpdate[]
  notifications       Notification[]
  liveVideoSessions   LiveVideoSession[]
  liveVideoLocationUpdates LiveVideoLocationUpdate[]
  sosEvents           SosEvent[]
  reports             Report[]
  broadcasts          Broadcast[]
  communityPosts      CommunityPost[]
  assignments         IncidentAssignment[]
  dispatchEvents      DispatchEvent[]

  @@index([country, state, lga])
  @@index([status, priority, createdAt])
  @@index([jurisdictionId, status])
  @@map("incidents")
}

model IncidentMedia {
  id           String       @id @default(uuid()) @db.Uuid
  incidentId   String       @map("incident_id") @db.Uuid
  uploaderId   String       @map("uploader_id") @db.Uuid
  mediaType    MediaType    @map("media_type")
  bucket       String
  objectKey    String       @map("object_key")
  contentType  String       @map("content_type")
  sizeBytes    BigInt?      @map("size_bytes")
  fileHash     String       @map("file_hash")
  capturedAt   DateTime     @map("captured_at") @db.Timestamptz(6)
  uploadedAt   DateTime     @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  latitude     Decimal      @db.Decimal(9, 6)
  longitude    Decimal      @db.Decimal(9, 6)
  gpsLocation  Unsupported("geography(Point,4326)") @map("gps_location")
  metadata     Json         @default("{}")
  incident     Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploader     User         @relation("MediaUploader", fields: [uploaderId], references: [id])
  accessLogs   IncidentMediaAccessLog[]

  @@unique([fileHash])
  @@index([incidentId])
  @@index([uploaderId])
  @@map("incident_media")
}

model IncidentMediaAccessLog {
  id          String        @id @default(uuid()) @db.Uuid
  mediaId     String        @map("media_id") @db.Uuid
  accessorId  String?       @map("accessor_id") @db.Uuid
  adminUserId String?       @map("admin_user_id") @db.Uuid
  action      String
  reason      String?
  ipAddress   String?       @map("ip_address") @db.Inet
  userAgent   String?       @map("user_agent")
  accessedAt  DateTime      @default(now()) @map("accessed_at") @db.Timestamptz(6)
  media       IncidentMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  accessor    User?         @relation(fields: [accessorId], references: [id])

  @@index([mediaId, accessedAt])
  @@index([accessorId])
  @@map("incident_media_access_logs")
}

model IncidentVerification {
  id           String    @id @default(uuid()) @db.Uuid
  incidentId   String    @map("incident_id") @db.Uuid
  verifierId   String?   @map("verifier_id") @db.Uuid
  method       String
  result       String
  confidence   Decimal?  @db.Decimal(5, 2)
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  incident     Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  verifier     User?     @relation(fields: [verifierId], references: [id])

  @@index([incidentId, result])
  @@map("incident_verifications")
}

model IncidentTimeline {
  id          String   @id @default(uuid()) @db.Uuid
  incidentId  String   @map("incident_id") @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  actorType   String   @map("actor_type")
  eventType   String   @map("event_type")
  message     String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorId], references: [id])

  @@index([incidentId, createdAt])
  @@map("incident_timeline")
}

model IncidentStatusHistory {
  id          String          @id @default(uuid()) @db.Uuid
  incidentId  String          @map("incident_id") @db.Uuid
  fromStatus  IncidentStatus? @map("from_status")
  toStatus    IncidentStatus  @map("to_status")
  changedById String?         @map("changed_by_id") @db.Uuid
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  incident    Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  changedBy   User?           @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([incidentId, createdAt])
  @@map("incident_status_history")
}

model IncidentLocationUpdate {
  id             String   @id @default(uuid()) @db.Uuid
  incidentId     String   @map("incident_id") @db.Uuid
  latitude       Decimal  @db.Decimal(9, 6)
  longitude      Decimal  @db.Decimal(9, 6)
  accuracy       Decimal? @db.Decimal(8, 2)
  gpsLocation    Unsupported("geography(Point,4326)") @map("gps_location")
  capturedAt     DateTime @map("captured_at") @db.Timestamptz(6)
  receivedAt     DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  sourceDeviceId String?  @map("source_device_id")
  sequenceNumber Int      @default(0) @map("sequence_number")
  metadata       Json     @default("{}")
  incident       Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, capturedAt])
  @@map("incident_location_updates")
}

model Broadcast {
  id             String          @id @default(uuid()) @db.Uuid
  jurisdictionId String?         @map("jurisdiction_id") @db.Uuid
  incidentId      String?         @map("incident_id") @db.Uuid
  creatorAdminId String          @map("creator_admin_id") @db.Uuid
  approverAdminId String?        @map("approver_admin_id") @db.Uuid
  type           BroadcastType
  title          String
  body           String
  status         BroadcastStatus @default(Draft)
  priority       IncidentPriority @default(P4GeneralSafety)
  requiresApproval Boolean       @default(true) @map("requires_approval")
  autoPublished    Boolean       @default(false) @map("auto_published")
  targetRadiusMeters Int?        @map("target_radius_meters")
  targetArea     Unsupported("geography(MultiPolygon,4326)")? @map("target_area")
  targetCenter   Unsupported("geography(Point,4326)")? @map("target_center")
  rejectedReason String?         @map("rejected_reason")
  publishedAt    DateTime?       @map("published_at") @db.Timestamptz(6)
  scheduledAt    DateTime?       @map("scheduled_at") @db.Timestamptz(6)
  dispatchQueuedAt DateTime?     @map("dispatch_queued_at") @db.Timestamptz(6)
  dispatchStartedAt DateTime?    @map("dispatch_started_at") @db.Timestamptz(6)
  dispatchCompletedAt DateTime?  @map("dispatch_completed_at") @db.Timestamptz(6)
  dispatchFailureReason String?  @map("dispatch_failure_reason")
  expiresAt      DateTime?       @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  jurisdiction   Jurisdiction?   @relation(fields: [jurisdictionId], references: [id])
  incident        Incident?       @relation(fields: [incidentId], references: [id])
  creator        AdminUser       @relation("BroadcastCreator", fields: [creatorAdminId], references: [id])
  approver       AdminUser?      @relation("BroadcastApprover", fields: [approverAdminId], references: [id])
  notifications  Notification[]
  deliveries     BroadcastDelivery[]
  reads          BroadcastRead[]
  communityPosts CommunityPost[]

  @@index([status, publishedAt])
  @@index([type, status])
  @@index([jurisdictionId])
  @@index([incidentId])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
  @@map("broadcasts")
}

model BroadcastRead {
  id          String    @id @default(uuid()) @db.Uuid
  broadcastId String    @map("broadcast_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  readAt      DateTime  @default(now()) @map("read_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId])
  @@index([userId, readAt])
  @@map("broadcast_reads")
}

model BroadcastDelivery {
  id             String                  @id @default(uuid()) @db.Uuid
  broadcastId    String                  @map("broadcast_id") @db.Uuid
  userId         String                  @map("user_id") @db.Uuid
  notificationId String?                 @map("notification_id") @db.Uuid
  distanceMeters Decimal?                @map("distance_meters") @db.Decimal(10, 2)
  status         BroadcastDeliveryStatus @default(Queued)
  channel        String                  @default("push")
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  sentAt         DateTime?               @map("sent_at") @db.Timestamptz(6)
  readAt         DateTime?               @map("read_at") @db.Timestamptz(6)
  broadcast      Broadcast               @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification?           @relation(fields: [notificationId], references: [id])

  @@unique([broadcastId, userId])
  @@index([userId, status, createdAt])
  @@index([broadcastId, status])
  @@map("broadcast_deliveries")
}

model Vehicle {
  id            String                @id @default(uuid()) @db.Uuid
  ownerId       String?               @map("owner_id") @db.Uuid
  plateNumber   String                @unique @map("plate_number")
  vin           String?               @unique
  make          String
  model         String
  color         String?
  year          Int?
