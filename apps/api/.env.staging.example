# THE EYE API — staging environment
# Copy to apps/api/.env for staging deploys. NEVER use these values in production.
# Staging Firebase project: the-eye-2stg

THE_EYE_APP_ENV=staging
NODE_ENV=staging
PORT=4000

# Required for POST /auth/google (legacy direct Google login). Not used by POST /auth/firebase/exchange.
# Staging mobile web client: 767357461507-rvoedt7hr8452sehgi2qs3v8q69vovuj.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=

DATABASE_URL="postgresql://USER:PASSWORD@STAGING_DB_HOST:5432/the_eye_staging?schema=public&sslmode=require"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@STAGING_DB_HOST:5432/the_eye_staging?schema=public&sslmode=require"

JWT_ACCESS_SECRET=changeme-staging-access-secret-32-chars-min
JWT_REFRESH_SECRET=changeme-staging-refresh-secret-32-chars-min

FCM_PROJECT_ID=the-eye-2stg
FIREBASE_PROJECT_ID=the-eye-2stg
# Inject via secret manager — do not commit real credentials
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

CORS_ORIGINS=https://staging-dashboard8jps.theeye.com.ng

# Auth delivery webhooks (required on staging for password reset + phone OTP)
AUTH_PASSWORD_RESET_WEBHOOK_URL=
AUTH_PHONE_OTP_WEBHOOK_URL=
# Optional shared secret sent as x-the-eye-delivery-secret
AUTH_DELIVERY_WEBHOOK_SECRET=

# Optional: probe seeded accounts after API is reachable
STAGING_API_BASE_URL=https://staging-api.theeye.com.ng/v1

# ---------------------------------------------------------------------------
# Staging test accounts (idempotent seed — staging only, never production)
# Set real values in your untracked .env / secret manager. Placeholders only here.
# ---------------------------------------------------------------------------

STAGING_TEST_SUPER_ADMIN_EMAIL=staging.superadmin@theeye.local
STAGING_TEST_SUPER_ADMIN_PASSWORD=changeme-staging-super-admin

STAGING_TEST_COUNTRY_ADMIN_EMAIL=staging.countryadmin@theeye.local
STAGING_TEST_COUNTRY_ADMIN_PASSWORD=changeme-staging-country-admin

STAGING_TEST_STATE_ADMIN_EMAIL=staging.stateadmin@theeye.local
STAGING_TEST_STATE_ADMIN_PASSWORD=changeme-staging-state-admin

STAGING_TEST_LGA_ADMIN_EMAIL=staging.lgaadmin@theeye.local
STAGING_TEST_LGA_ADMIN_PASSWORD=changeme-staging-lga-admin

STAGING_TEST_AGENCY_OFFICER_EMAIL=staging.agencyofficer@theeye.local
STAGING_TEST_AGENCY_OFFICER_PASSWORD=changeme-staging-agency-officer

STAGING_TEST_NEIGHBORHOOD_WATCH_ADMIN_EMAIL=staging.nwadmin@theeye.local
