# Copy to apps/api/.env for local development. Never commit apps/api/.env.

# Use the raw password inside quotes. Avoid URL-encoding ($ as %24) — Prisma may reject it on Windows.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/the_eye?schema=public&sslmode=disable"
DATABASE_DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/the_eye?schema=public&sslmode=disable"
PORT=4000
NODE_ENV=development
THE_EYE_APP_ENV=development
JWT_ACCESS_SECRET=dev-access-secret-32-chars-minimum!!
JWT_REFRESH_SECRET=dev-refresh-secret-32-chars-minimum!!
THE_EYE_DISABLE_REDIS=1
CORS_ORIGINS=http://localhost:3000
ADMIN_EMAIL=dev-admin@theeye.local
ADMIN_PASSWORD=change_me_dev_admin_password

# Staging-only test accounts — see apps/api/.env.staging.example and docs/staging-test-accounts.md
# Never set STAGING_TEST_* credentials in production. Seed with: pnpm --filter @the-eye/api run seed:staging:test-accounts
# STAGING_TEST_SUPER_ADMIN_EMAIL=
# STAGING_TEST_SUPER_ADMIN_PASSWORD=

# Firebase Cloud Messaging — use credentials from the matching environment project.
# development: the-eye-29cff | staging: the-eye-2stg | production: the-eye-2pd-d0217
# https://console.firebase.google.com/project/the-eye-29cff/settings/serviceaccounts/adminsdk
FCM_PROJECT_ID=the-eye-29cff
# Social sign-in token verification — must match the mobile/watch Firebase project for this API environment.
# development: the-eye-29cff | staging: the-eye-2stg | production: the-eye-2pd-d0217
FIREBASE_PROJECT_ID=the-eye-29cff
# Option A: inline service account fields (inject via secret manager in staging/production)
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
# Option B: full service account JSON (single secret blob)
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"the-eye-29cff","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com"}
# Option C: path to mounted credentials file
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-admin.json
# FCM_ALLOW_SIMULATION=true  # development only
