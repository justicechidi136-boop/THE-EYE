# THE EYE admin dashboard — staging build/deploy
# Prefer Docker build-args (no .env.production.local in images):
#   docker build --build-arg NEXT_PUBLIC_APP_ENV=staging \
#     --build-arg NEXT_PUBLIC_API_BASE_URL=<your-staging-https-api-url> \
#     -f apps/admin-web/Dockerfile -t the-eye-admin:staging .

NEXT_PUBLIC_APP_ENV=staging

# For nginx compose on one host, a relative path is valid:
NEXT_PUBLIC_API_BASE_URL=/v1
# For split-host deployments (App Platform / CDN), use your staging HTTPS API URL instead.

# Internal Docker service name — nginx serves the browser on / and proxies /v1 to api
# Runtime (docker-compose) — server-side API routes (login, SSR). Lowercase hostname required.
API_ORIGIN=http://api:4000

# Must match staging JWT_ACCESS_SECRET on the API service
JWT_ACCESS_SECRET=change_me_staging_access_secret

# ---------------------------------------------------------------------------
# Firebase Web Client — NOT REQUIRED (see .env.local.example)
# ---------------------------------------------------------------------------
# Staging Firebase project for mobile/API push: the-eye-2stg
# Do not set NEXT_PUBLIC_FIREBASE_* until a browser Firebase SDK feature is implemented.
#
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=the-eye-2stg
# NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=the-eye-2stg.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
