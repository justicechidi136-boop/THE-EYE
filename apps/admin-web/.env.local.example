# THE EYE admin dashboard — local development
# Copy to apps/admin-web/.env.local (gitignored)

# Environment label inlined into the browser bundle at build time
NEXT_PUBLIC_APP_ENV=local

# Server-side API origin for SSR, middleware, and /api/auth routes (not exposed to browser)
API_ORIGIN=http://localhost:4000

# Public API base URL. Use a path when nginx proxies /v1; use a full URL for direct API access.
NEXT_PUBLIC_API_BASE_URL=/v1
# Legacy alias — NEXT_PUBLIC_API_BASE_URL takes precedence when both are set
NEXT_PUBLIC_API_URL=/v1

# Must match JWT_ACCESS_SECRET in apps/api/.env so login cookies verify in middleware
JWT_ACCESS_SECRET=dev-access-secret-32-chars-minimum!!

# ---------------------------------------------------------------------------
# Firebase Web Client — NOT REQUIRED
# ---------------------------------------------------------------------------
# Admin auth is NestJS email/password → JWT httpOnly cookies (/api/auth/login → /v1/auth/login).
# Push notifications are dispatched server-side via Firebase Admin SDK (apps/api FCM_* env vars).
# This dashboard does not use Google sign-in, browser FCM, App Check, or Firebase Analytics.
#
# No Firebase web apps are registered for admin-web. Do not add firebase/* client SDKs unless
# a future feature needs browser-side Firebase (e.g. Google sign-in popup).
#
# If required later, register a Web app per environment in Firebase Console and set placeholders:
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=the-eye-29cff
# NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=the-eye-29cff.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
