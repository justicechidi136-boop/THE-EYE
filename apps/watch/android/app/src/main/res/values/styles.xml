<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Black launch window with centered THE EYE logo — no white flash. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:colorBackground">@color/boot_black</item>
        <item name="android:navigationBarColor">@color/boot_black</item>
        <item name="android:statusBarColor">@color/boot_black</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/boot_black</item>
        <item name="android:colorBackground">@color/boot_black</item>
        <item name="android:navigationBarColor">@color/boot_black</item>
        <item name="android:statusBarColor">@color/boot_black</item>
    </style>
</resources>
