# THE EYE container environment
# Copy to .env and replace change_me* placeholders. Never commit .env.

THE_EYE_IMAGE_TAG=local
# Optional: override image ref for scripts/validate-api-runtime-image.cjs (defaults to compose-resolved the-eye-api tag)
# THE_EYE_API_IMAGE=the-eye-api:local

# Public ports
HTTP_PORT=80
HTTPS_PORT=443
API_PORT=4000
ADMIN_WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
LIVEKIT_HTTP_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_PORT=7882

# TLS / nginx (production)
# Legacy fallback for admin hostname when THE_EYE_ADMIN_SERVER_NAME is unset.
THE_EYE_SERVER_NAME=admin.example.com
THE_EYE_ADMIN_SERVER_NAME=admin.example.com
THE_EYE_API_SERVER_NAME=api.example.com
THE_EYE_LIVEKIT_SERVER_NAME=livekit.example.com
# Redirect all HTTP traffic to HTTPS after certificates are installed.
THE_EYE_SSL_REDIRECT=false
# Auto: serve HTTP-only when certs are missing (ACME bootstrap). Set false to fail fast.
THE_EYE_TLS_BOOTSTRAP=auto
# Development only: auto-generate self-signed certs on nginx start if files are missing.
THE_EYE_GENERATE_DEV_SSL=false

# PostgreSQL + PostGIS
POSTGRES_DB=the_eye
POSTGRES_USER=the_eye
POSTGRES_PASSWORD=change_me_postgres
# Direct Postgres — use for prisma migrate deploy, prisma db seed, and admin tools
DATABASE_DIRECT_URL=postgresql://the_eye:change_me_postgres@postgres-postgis:5432/the_eye?schema=public
# Runtime URL — point at PgBouncer in production (see docs/postgres-scaling.md)
DATABASE_URL=postgresql://the_eye:change_me_postgres@postgres-postgis:5432/the_eye?schema=public&connection_limit=10&pool_timeout=20
# When using the pooling profile: DATABASE_URL=postgresql://the_eye:change_me_postgres@pgbouncer:6432/the_eye?schema=public&pgbouncer=true&connection_limit=5&pool_timeout=20
PGBOUNCER_PORT=6432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO / S3
MINIO_ROOT_USER=the_eye_minio
MINIO_ROOT_PASSWORD=change_me_minio_secret
S3_ENDPOINT=http://minio:9000
S3_BUCKET=the-eye
S3_ACCESS_KEY=the_eye_minio
S3_SECRET_KEY=change_me_minio_secret

# LiveKit
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.example.com

# API secrets
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LIVE_LOCATION_LINK_SECRET=change_me_live_location_secret
CORS_ORIGINS=https://admin.example.com
GOOGLE_OAUTH_CLIENT_ID=change_me_google_oauth_client_id
# Per-environment Firebase project (must match mobile/watch flavor + FCM credentials)
# development: the-eye-29cff | staging: the-eye-2stg | production: the-eye-2pd-d0217
FIREBASE_PROJECT_ID=the-eye-2stg
ALLOW_DEV_AUTH_CODES=false
ENABLE_SWAGGER=false
REDIS_PASSWORD=change_me_redis_secret
TRUST_PROXY_HOPS=2
JSON_BODY_LIMIT=10mb

# Admin web — canonical API is THE_EYE_API_SERVER_NAME/v1 (not the admin hostname)
# Build-time args for admin-web image (see apps/admin-web/Dockerfile)
ADMIN_WEB_APP_ENV=staging
# API runtime environment — drives Firebase guards and BullMQ queue isolation (development | staging | production)
THE_EYE_APP_ENV=staging
# Client/browser API base URL (baked into Next.js bundle at build time)
NEXT_PUBLIC_API_BASE_URL=https://staging-api.theeye.com.ng/v1
# Server-side only: admin-web container → api service on Docker network (login, SSR, API routes)
# Set in docker-compose runtime env — not embedded in client bundles
# Use lowercase hostname (http://api:4000) — Docker DNS registers the compose service as `api`
API_ORIGIN=http://api:4000

# Disposable development/staging admin login (set real values in local .env only — never use in production)
ADMIN_EMAIL=dev-admin@theeye.local
ADMIN_PASSWORD=change_me_dev_admin_password

# Staging VPS: after migrate, bootstrap admin login (replace placeholders — never commit real passwords):
#   docker compose -f infra/docker/docker-compose.yml --env-file .env --profile tools run --rm api-create-admin
# Full staging QA accounts (STAGING_TEST_*): copy apps/api/.env.staging.example, then:
#   docker compose -f infra/docker/docker-compose.yml --env-file .env --profile tools run --rm api-seed-staging
# See docs/staging-test-accounts.md

# Mobile app build arg (Flutter --dart-define=THE_EYE_API_URL=...)
THE_EYE_API_URL=http://localhost:4000/v1

# Prometheus (optional observability profile)
PROMETHEUS_PORT=9090
# Let's Encrypt registration email — read by scripts/issue-letsencrypt.sh after sourcing .env
CERTBOT_EMAIL=ops@example.com
# Staging VPS: set FCM_PROJECT_ID and FIREBASE_PROJECT_ID to the-eye-2stg (never the-eye-29cff or production).
FCM_PROJECT_ID=the-eye-2stg
FIREBASE_PROJECT_ID=the-eye-2stg
# Inject via secret manager — never commit real keys
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"the-eye-29cff",...}
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-admin.json
# FCM_ALLOW_SIMULATION=true  # development only; must be unset/false in production

# Prometheus scrape token (required in production — nginx blocks public /metrics)
METRICS_BEARER_TOKEN=change_me_metrics_token_32_chars_min

SMS_PROVIDER_DISABLED=true
EMAIL_PROVIDER_DISABLED=true
# Rate limiting uses the same Redis instance as BullMQ.
# When Redis is disabled (THE_EYE_DISABLE_REDIS=1), in-memory counters are used for local dev/tests.
# Prometheus metrics are exposed at GET /metrics (see docs/grafana-dashboard.md).
# THE_EYE_DISABLE_METRICS_POLLING=1
