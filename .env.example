# THE EYE container environment

THE_EYE_IMAGE_TAG=local

# Public ports
HTTP_PORT=80
HTTPS_PORT=443
API_PORT=4000
ADMIN_WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
LIVEKIT_HTTP_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_PORT=7882

# PostgreSQL + PostGIS
POSTGRES_DB=the_eye
POSTGRES_USER=the_eye
POSTGRES_PASSWORD=change_me_postgres
DATABASE_URL=postgresql://the_eye:change_me_postgres@postgres-postgis:5432/the_eye?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO / S3
MINIO_ROOT_USER=the_eye_minio
MINIO_ROOT_PASSWORD=change_me_minio_secret
S3_ENDPOINT=http://minio:9000
S3_BUCKET=the-eye
S3_ACCESS_KEY=the_eye_minio
S3_SECRET_KEY=change_me_minio_secret

# LiveKit
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
NEXT_PUBLIC_LIVEKIT_URL=wss://example.com/livekit

# API secrets
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LIVE_LOCATION_LINK_SECRET=change_me_live_location_secret
CORS_ORIGINS=https://admin.example.com
GOOGLE_OAUTH_CLIENT_ID=
ALLOW_DEV_AUTH_CODES=false
ENABLE_SWAGGER=false
REDIS_PASSWORD=change_me_redis_secret

# Admin web
NEXT_PUBLIC_API_URL=/v1

# Optional external providers
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
SMS_PROVIDER_DISABLED=true
EMAIL_PROVIDER_DISABLED=true
