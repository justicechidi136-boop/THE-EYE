# ${THE_EYE_SERVICE_LABEL} — HTTPS (port 443)
server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;
  server_name ${THE_EYE_SERVER_NAME};

  ssl_certificate ${THE_EYE_SSL_CERT};
  ssl_certificate_key ${THE_EYE_SSL_KEY};
  include /etc/nginx/snippets/ssl-params.conf;

  include /etc/nginx/snippets/healthz.conf;

  include /etc/nginx/snippets/${THE_EYE_LOCATIONS_SNIPPET};
}
