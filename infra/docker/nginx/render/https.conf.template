# Port 443 — TLS termination for production traffic.
server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;
  server_name ${THE_EYE_SERVER_NAME};

  ssl_certificate /etc/nginx/certs/live/fullchain.pem;
  ssl_certificate_key /etc/nginx/certs/live/privkey.pem;
  include /etc/nginx/snippets/ssl-params.conf;

  include /etc/nginx/snippets/the-eye-locations.conf;
}
